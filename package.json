{
  "name": "trend-screener",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "build:server": "node --check server/index.js && node --check server/scanJob.js && node --check server/backtestJob.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "scan": "node server/scanJob.js",
    "backtest": "node server/backtestJob.js",
    "start": "node server/index.js",
    "ml:collect": "node server/ml/dataPipeline.js --collect",
    "ml:collect:days": "node server/ml/dataPipeline.js --collect --days",
    "ml:backfill": "node server/ml/labels.js --backfill",
    "ml:train": "node server/ml/train.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "@tensorflow/tfjs": "^4.22.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lightweight-charts": "^5.0.9",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  }
}
