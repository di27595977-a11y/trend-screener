  "patternDetectionDefaults": {
    "lookback": 3,
    "supportResistanceTolerance": 0.005,
    "reversalTolerance": 0.02,
    "minHarmonicConfidence": 0.7
  },
  "supportResistance": {
    "priceClusteringTolerance": 0.005,
    "minimumTouches": 2,
    "maxLevelsReturned": 6,
    "summaryLevelsUsed": 2
  },
  "triangleDetection": {
    "recentHighsUsed": 4,
    "recentLowsUsed": 4,
    "requireUpperSlopeLessThanOrEqualLowerSlope": true,
    "rejectIfParallel": true,
    "apexMustBeAfterLastSwing": true,
    "apexMaxForwardDistanceRatio": 0.5,
    "flatSlopeThreshold": 0.0001,
    "types": [
      "ascending",
      "descending",
      "symmetric"
    ]
  },
  "reversalDetection": {
    "wBottom": {
      "priceTolerance": 0.02,
      "spacingBarsMin": 5,
      "spacingBarsMax": 48,
      "necklineMustExceedFeetByAtLeastPercent": 1
    },
    "mTop": {
      "priceTolerance": 0.02,
      "spacingBarsMin": 5,
      "spacingBarsMax": 48,
      "necklineMustBeBelowPeaksByAtLeastPercent": 1
    }
  },
  "harmonicDetection": {
