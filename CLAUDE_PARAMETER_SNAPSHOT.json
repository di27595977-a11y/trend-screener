{
  "snapshotDate": "2026-03-20",
  "source": "Repository code defaults and current UI defaults",
  "notes": [
    "No local .env override file was found in this workspace, so environment-driven runtime overrides may differ in deployed environments.",
    "Secrets and tokens are intentionally omitted."
  ],
  "marketUniverse": {
    "exchange": "Binance Futures",
    "product": "USDT-M perpetual contracts",
    "symbolFilter": {
      "status": "TRADING",
      "contractType": "PERPETUAL",
      "quoteAsset": "USDT"
    }
  },
  "scanTimeframes": {
    "1h": {
      "interval": "1h",
      "scanCandleLimit": 24,
      "sparklineLimit": 24
    },
    "4h": {
      "interval": "4h",
      "scanCandleLimit": 72,
      "sparklineLimit": 72
    }
  },
  "trendThresholds": {
    "minRSquared": 0.6,
    "slopeMustBePositive": true,
    "maxPullbackRatio": 0.35,
    "minVolumeRatio": 1.1,
    "minPriceChangePercent": 3,
    "maxPriceChangePercent": 50,
    "preferredPositionMin": 0.4,
    "preferredPositionMax": 0.7
  },
  "trendMetrics": {
    "linearRegression": {
      "input": "close prices",
      "outputs": [
        "slope",
        "intercept",
        "rSquared"
      ]
    },
    "pullbackRatio": "After the highest high in the window, measure how deep price pulls back relative to full range.",
    "volumeRatio": "average up-candle volume / average down-candle volume",
    "priceChangePercent": "(lastClose - firstClose) / firstClose * 100",
    "positionScore": "(currentPrice - rangeLow) / (rangeHigh - rangeLow)"
  },
  "trendScoring": {
    "weights": {
      "rSquared": 30,
      "pullbackRatio": 25,
      "volumeRatio": 20,
      "priceChange": 15,
      "positionScore": 10
    },
    "componentRules": {
      "rSquared": "clamp(rSquared, 0, 1)",
      "pullbackRatio": "max(1 - pullbackRatio / 0.5, 0)",
      "volumeRatio": "clamp(volumeRatio - 1, 0, 1)",
      "priceChange": "1 when 3 <= priceChange <= 50, else 0.3",
      "positionScore": "1 when 0.4 <= position <= 0.7, else 0.6 when 0.25 <= position <= 0.85, else 0.3"
    },
    "scoreOutput": "round(weighted sum)",
    "scoreBuckets": [
      "80+",
      "70-79",
      "60-69",
      "<60"
    ]
  },
  "scannerRuntime": {
    "apiBaseDefault": "https://fapi.binance.com",
    "requestsPerSecondDefault": 4,
    "symbolLimitDefault": null,
    "scanIntervalMinutesDefault": 5,
    "symbolListCacheMinutes": 60,
    "patternDetectionRunsOnTopNCandidates": 50,
    "patternDetectionBatchSizeFormula": "max(1, floor(requestsPerSecond / 2))",
    "refreshOrder": [
      "1h",
      "4h"
    ]
  },
  "dashboardDefaults": {
    "timeframe": "1h",
    "minScore": 55,
    "search": "",
    "patternFilters": {
      "triangle": false,
      "harmonic": false,
      "wBottom": false,
      "mTop": false
